generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  teacher
  student
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  role           Role
  name           String
  phone          String   @default("")
  avatarUrl      String   @default("")
  bio            String   @default("")
  teacherProfile Json?
  studentProfile Json?
  isActive           Boolean  @default(true)
  isDeleted          Boolean  @default(false)
  deletedAt          DateTime?
  deletedBy          String   @default("")
  mustChangePassword Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  noticesCreated           Notice[]
  marksAsTeacher           Mark[]                 @relation("MarkTeacher")
  marksAsStudent           Mark[]                 @relation("MarkStudent")
  attendanceAsTeacher      Attendance[]           @relation("AttTeacher")
  attendanceAsStudent      Attendance[]           @relation("AttStudent")
  studyMaterials           StudyMaterial[]
  feedbacks                Feedback[]
  admissionsReviewed       AdmissionApplication[] @relation("AdmReviewedBy")
  admissionsCreatedStudent AdmissionApplication[] @relation("AdmCreatedStudent")
  placementApplications    PlacementApplication[] @relation("PlacementAppStudent")
  leaveRequests            LeaveRequest[]         @relation("TeacherLeave")
  libraryIssues            LibraryIssue[]         @relation("LibraryIssueStudent")
  resetTokens              PasswordResetToken[]
}

model AdmissionApplication {
  id                   String    @id @default(cuid())
  applicationNumber    String    @unique
  fullName             String
  email                String
  phone                String
  address              String
  courseApplied        String
  board12              String    @default("")
  marks12              Float
  maxMarks12           Float     @default(600)
  dob                  String    @default("")
  gender               String    @default("Male")
  parentContact        String    @default("")
  sscMarks             Float     @default(0)
  previousCollege      String    @default("")
  passingYear          Int       @default(2026)
  category             String    @default("General")
  documentFiles        Json      @default("[]")
  status               String    @default("pending")
  verificationNotes    String    @default("")
  documentsVerified    Boolean   @default(false)
  reviewedById         String?
  reviewedBy           User?     @relation("AdmReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt           DateTime?
  createdStudentUserId String?
  createdStudentUser   User?     @relation("AdmCreatedStudent", fields: [createdStudentUserId], references: [id], onDelete: SetNull)
  tempPasswordHint     String    @default("")
  academicYear         Int
  isDeleted            Boolean   @default(false)
  deletedAt            DateTime?
  deletedBy            String    @default("")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([email, courseApplied, academicYear])
  @@index([email])
  @@index([isDeleted])
}

model Notice {
  id           String    @id @default(cuid())
  title        String
  body         String    @default("")
  priority     String    @default("NORMAL")
  audience     String    @default("ALL")
  publishDate  DateTime  @default(now())
  expiryDate   DateTime?
  pdfFile      Json?
  attachment   Json?
  isPublished  Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String    @default("")
  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String
  stream      String   @default("Other")
  hodName     String   @default("")
  description String   @default("")
  subjects    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
}

model Course {
  id           String      @id @default(cuid())
  name         String
  level        String
  duration     String      @default("")
  eligibility  String      @default("")
  description  String      @default("")
  seatsApprox  Int         @default(0)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  deletedBy    String      @default("")
  updatedAt    DateTime    @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  caption   String   @default("")
  imageFile Json
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  message   String
  rating    Int      @default(5)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyMaterial {
  id        String   @id @default(cuid())
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  title     String
  subject   String
  className String
  file      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mark {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation("MarkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId     String
  teacher       User     @relation("MarkTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject       String
  examName      String
  marksObtained Float
  maxMarks      Float
  term          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([studentId, subject, examName])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("AttStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User     @relation("AttTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject   String
  date      DateTime
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subject, date])
}

model CollegeSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Counter {
  id        String   @id @default(cuid())
  name      String   @unique
  value     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id                  String           @id @default(cuid())
  companyName         String
  industry            String           @default("")
  website             String           @default("")
  description         String           @default("")
  packageOffered      String           @default("")
  eligibilityCriteria String           @default("")
  location            String           @default("")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  placementDrives     PlacementDrive[]
}

model PlacementDrive {
  id                  String                 @id @default(cuid())
  companyId           String
  company             Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title               String
  description         String                 @default("")
  driveDate           DateTime?
  applicationDeadline DateTime?
  status              String                 @default("active")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  applications        PlacementApplication[]

  @@index([companyId])
}

model PlacementApplication {
  id                String         @id @default(cuid())
  studentId         String
  student           User           @relation("PlacementAppStudent", fields: [studentId], references: [id], onDelete: Cascade)
  driveId           String
  drive             PlacementDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)
  applicationStatus String         @default("applied")
  appliedAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([studentId, driveId])
  @@index([driveId])
}

model LeaveRequest {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     User     @relation("TeacherLeave", fields: [teacherId], references: [id], onDelete: Cascade)
  fromDate    DateTime
  toDate      DateTime
  reason      String
  leaveType   String   @default("casual")
  status      String   @default("pending")
  adminNote   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId])
}

model Timetable {
  id        String   @id @default(cuid())
  className String
  weekLabel String   @default("current")
  slots     Json     @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([className, weekLabel])
  @@index([className])
}

model LibraryBook {
  id            String         @id @default(cuid())
  title         String
  author        String         @default("")
  category      String         @default("")
  isbn          String         @default("")
  totalQty      Int            @default(1)
  availableQty  Int            @default(1)
  shelfLocation String         @default("")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  issues        LibraryIssue[]

  @@index([isbn])
}

model LibraryIssue {
  id         String      @id @default(cuid())
  bookId     String
  book       LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  studentId  String
  student    User        @relation("LibraryIssueStudent", fields: [studentId], references: [id], onDelete: Cascade)
  issuedAt   DateTime    @default(now())
  dueDate    DateTime
  returnedAt DateTime?
  status     String      @default("issued")
  fine       Float       @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([studentId])
  @@index([bookId])
}

model Exam {
  id          String    @id @default(cuid())
  title       String
  examType    String    @default("internal")
  className   String
  subject     String
  examDate    DateTime?
  startTime   String    @default("")
  duration    String    @default("")
  venue       String    @default("")
  maxMarks    Float     @default(100)
  isPublished Boolean   @default(false)
  resultsPublished Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([className])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userRole  String   @default("")
  action    String
  target    String
  details   String   @default("{}")
  ipAddress String   @default("")
  userAgent String   @default("")
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}
