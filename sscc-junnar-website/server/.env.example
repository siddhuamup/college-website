# Copy this file to `.env` in this same folder (server/), then edit values.
# Commands: npx prisma db push   →   npm run seed   →   npm start

PORT=3000

# SQLite file path is relative to the `prisma/` directory (not project root).
# Creates/opens: server/prisma/dev.db
DATABASE_URL="file:./dev.db"

# Optional: fixed path on Windows (forward slashes work)
# DATABASE_URL="file:C:/data/sscc-college.db"

# Used to sign login tokens — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-string-in-production

JWT_EXPIRES_IN=7d

# Secret shown only in server/.env — used to open /admin (not exposed in public UI).
# Must match what you type once on the admin access screen; use a long random value in production.
ADMIN_ACCESS_KEY=change-this-to-a-long-random-access-key
